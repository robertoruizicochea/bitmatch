// ─── PARTICLE SYSTEM ─────────────────────────────────────────────────────────
function HeartParticles({ active, onComplete }) {
  const particles = Array.from({ length: 20 }, (_, i) => ({
    id: i,
    x: 40 + Math.random() * 20,
    vx: (Math.random() - 0.5) * 8,
    vy: -(3 + Math.random() * 5),
    size: 8 + Math.random() * 16,
    delay: Math.random() * 0.3,
    emoji: ["❤️","💛","🧡","💖","⚡","₿"][Math.floor(Math.random()*6)],
  }));

  useEffect(() => {
    if (active) {
      const t = setTimeout(onComplete, 1500);
      return () => clearTimeout(t);
    }
  }, [active]);

  if (!active) return null;

  return (
    <div style={{ position: "fixed", inset: 0, pointerEvents: "none", zIndex: 9999 }}>
      {particles.map(p => (
        <div
          key={p.id}
          style={{
            position: "absolute",
            left: `${p.x}%`,
            bottom: "50%",
            fontSize: p.size,
            animation: `particleFloat 1.2s ease-out ${p.delay}s forwards`,
            "--vx": `${p.vx * 20}px`,
            "--vy": `${p.vy * 30}px`,
          }}
        >
          {p.emoji}
        </div>
      ))}
    </div>
  );
}

// ─── SWIPE CARD ───────────────────────────────────────────────────────────────
function SwipeCard({ profile, onSwipe, isTop }) {
  const cardRef = useRef(null);
  const startX = useRef(0);
  const currentX = useRef(0);
  const isDragging = useRef(false);
  const [dragOffset, setDragOffset] = useState(0);
  const [dragDir, setDragDir] = useState(null);

  const handleMouseDown = (e) => {
    if (!isTop) return;
    isDragging.current = true;
    startX.current = e.clientX || e.touches?.[0]?.clientX;
  };

  const handleMouseMove = (e) => {
    if (!isDragging.current) return;
    const x = e.clientX || e.touches?.[0]?.clientX;
    const diff = x - startX.current;
    currentX.current = diff;
    setDragOffset(diff);
    setDragDir(diff > 30 ? "right" : diff < -30 ? "left" : null);
  };

  const handleMouseUp = () => {
    if (!isDragging.current) return;
    isDragging.current = false;
    const threshold = 100;
    if (currentX.current > threshold) {
      onSwipe("right", profile);
    } else if (currentX.current < -threshold) {
      onSwipe("left", profile);
    }
    setDragOffset(0);
    setDragDir(null);
    currentX.current = 0;
  };

  const rotation = dragOffset * 0.08;
  const opacity = 1 - Math.abs(dragOffset) / 500;

  return (
    <div
      ref={cardRef}
      onMouseDown={handleMouseDown}
      onMouseMove={handleMouseMove}
      onMouseUp={handleMouseUp}
      onMouseLeave={handleMouseUp}
      onTouchStart={handleMouseDown}
      onTouchMove={handleMouseMove}
      onTouchEnd={handleMouseUp}
      style={{
        position: "absolute",
        width: "100%",
        maxWidth: 380,
        cursor: isTop ? "grab" : "default",
        transform: `translateX(${dragOffset}px) rotate(${rotation}deg) scale(${isTop ? 1 : 0.95})`,
        transition: isDragging.current ? "none" : "transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275)",
        zIndex: isTop ? 10 : 5,
        userSelect: "none",
        touchAction: "none",
      }}
    >
      {/* Overlay indicators */}
      {dragDir === "right" && (
        <div style={{
          position: "absolute", top: 24, left: 24, zIndex: 20,
          background: "rgba(249, 115, 22, 0.95)", borderRadius: 12, padding: "8px 20px",
          border: "3px solid #F97316", transform: "rotate(-15deg)",
          fontFamily: "'Playfair Display', serif", fontSize: 28, fontWeight: 900,
          color: "white", letterSpacing: 2,
        }}>❤️ HEART</div>
      )}
      {dragDir === "left" && (
        <div style={{
          position: "absolute", top: 24, right: 24, zIndex: 20,
          background: "rgba(30,30,30,0.95)", borderRadius: 12, padding: "8px 20px",
          border: "3px solid #555", transform: "rotate(15deg)",
          fontFamily: "'Playfair Display', serif", fontSize: 28, fontWeight: 900,
          color: "#888", letterSpacing: 2,
        }}>✕ PASS</div>
      )}

      {/* Card body */}
      <div style={{
        borderRadius: 28,
        overflow: "hidden",
        background: "#111",
        border: "1px solid rgba(249,115,22,0.2)",
        boxShadow: isTop
          ? "0 32px 80px rgba(0,0,0,0.8), 0 0 0 1px rgba(249,115,22,0.1)"
          : "0 8px 32px rgba(0,0,0,0.5)",
      }}>
        {/* Ordinal image area */}
        <div style={{
          height: 340,
          background: `linear-gradient(135deg, ${profile.ordinalColor}22, #0a0a0a 60%)`,
          position: "relative",
          overflow: "hidden",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
        }}>
          {/* Geometric Ordinal placeholder */}
          <div style={{
