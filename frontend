  const [walletConnected, setWalletConnected] = useState(false);
  const [notification, setNotification] = useState(null);

  const currentProfile = profiles[currentIndex];
  const nextProfile = profiles[currentIndex + 1];

  const showNotif = (msg) => {
    setNotification(msg);
    setTimeout(() => setNotification(null), 2000);
  };

  const handleSwipe = (direction, profile) => {
    if (direction === "right") {
      handleHeart(profile);
    } else {
      handlePass();
    }
  };

  const handleHeart = (profile = currentProfile) => {
    if (!profile) return;

    // Mint +1 $HEART
    setHeartBalance(h => h + 1);

    // ~40% chance of match for demo
    const isMatch = Math.random() > 0.6;

    if (isMatch) {
      setHeartBalance(h => h + 10);
      setMatchCount(m => m + 1);
      setShowParticles(true);
      setTimeout(() => setShowMatch(profile), 300);
    } else {
      showNotif(`❤️ +1 $HEART por el like`);
    }

    setCurrentIndex(i => i + 1);
  };

  const handlePass = () => {
    setCurrentIndex(i => i + 1);
  };

  const handleSuperHeart = () => {
    if (heartBalance < 1) return;
    setHeartBalance(h => h - 1);
    handleHeart();
    showNotif("⚡ Super Heart enviado!");
  };

  return (
    <>
      {/* Global styles */}
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Lora:ital,wght@0,400;0,600;1,400&family=Space+Mono:wght@400;700&display=swap');

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: #080808; }

        @keyframes particleFloat {
          0% { transform: translate(0, 0) scale(1); opacity: 1; }
          100% { transform: translate(var(--vx), var(--vy, -200px)) scale(0); opacity: 0; }
        }
        @keyframes fadeIn {
          from { opacity: 0; }
          to { opacity: 1; }
        }
        @keyframes slideDown {
          from { opacity: 0; transform: translateY(-30px); }
          to { opacity: 1; transform: translateY(0); }
        }
        @keyframes slideUp {
          from { opacity: 0; transform: translateY(30px); }
          to { opacity: 1; transform: translateY(0); }
        }
        @keyframes bounceIn {
          0% { opacity: 0; transform: scale(0.3); }
          50% { transform: scale(1.2); }
          100% { opacity: 1; transform: scale(1); }
        }
        @keyframes notifSlide {
          0% { opacity: 0; transform: translateX(-50%) translateY(20px); }
          20% { opacity: 1; transform: translateX(-50%) translateY(0); }
          80% { opacity: 1; transform: translateX(-50%) translateY(0); }
          100% { opacity: 0; transform: translateX(-50%) translateY(-20px); }
        }
        @keyframes pulse {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.5; }
        }
      `}</style>

      {/* Notification */}
      {notification && (
        <div style={{
          position: "fixed", bottom: 120, left: "50%",
          transform: "translateX(-50%)",
          background: "rgba(249,115,22,0.95)", borderRadius: 20,
          padding: "10px 20px", zIndex: 500,
          fontFamily: "'Space Mono', monospace",
          fontSize: 12, color: "#000", fontWeight: 700,
          animation: "notifSlide 2s ease forwards",
          whiteSpace: "nowrap",
        }}>
          {notification}
        </div>
      )}

      {/* Particles */}
      <HeartParticles
        active={showParticles}
        onComplete={() => setShowParticles(false)}
      />

      {/* Match modal */}
      {showMatch && (
        <MatchModal
          profile={showMatch}
          myHearts={heartBalance}
          onClose={() => setShowMatch(null)}
        />
      )}

      {/* App */}
      <div style={{
        minHeight: "100dvh",
        background: "#080808",
        display: "flex", flexDirection: "column",
        maxWidth: 440, margin: "0 auto",
        position: "relative",
      }}>
        {/* Ambient glow */}
        <div style={{
          position: "fixed", top: "20%", left: "50%",
          transform: "translateX(-50%)",
          width: 300, height: 300,
          borderRadius: "50%",
          background: "radial-gradient(circle, rgba(249,115,22,0.08) 0%, transparent 70%)",
          pointerEvents: "none",
        }} />

        <Header
          heartBalance={heartBalance}
          matchCount={matchCount}
          walletConnected={walletConnected}
          onConnect={() => setWalletConnected(v => !v)}
        />

        {/* Wallet warning */}
        {!walletConnected && (
          <div style={{
            margin: "12px 24px 0",
            padding: "10px 16px",
            background: "rgba(249,115,22,0.08)",
            border: "1px solid rgba(249,115,22,0.2)",
            borderRadius: 12,
            fontFamily: "'Space Mono', monospace",
            fontSize: 10, color: "#F97316",
            letterSpacing: 0.5,
            animation: "pulse 2s ease infinite",
          }}>
            ⚡ Conecta tu wallet para guardar matches on-chain en BOB L2
          </div>
        )}

        {/* Card stack */}
        <div style={{
          flex: 1,
          display: "flex",
          flexDirection: "column",
          alignItems: "center",
          justifyContent: "center",
          padding: "24px 24px 0",
          position: "relative",
          minHeight: 500,
        }}>
          {currentProfile ? (
            <div style={{
              position: "relative",
              width: "100%", maxWidth: 380,
              height: 560,
            }}>
              {/* Back card */}
              {nextProfile && (
                <SwipeCard
                  key={nextProfile.id + "-back"}
                  profile={nextProfile}
                  onSwipe={() => {}}
                  isTop={false}
                />
              )}
              {/* Top card */}
              <SwipeCard
                key={currentProfile.id}
                profile={currentProfile}
                onSwipe={handleSwipe}
                isTop={true}
              />
            </div>
          ) : (
            <EmptyState onReset={() => {
              setProfiles([...MOCK_PROFILES]);
              setCurrentIndex(0);
            }} />
          )}
        </div>

        {/* Bottom actions */}
        {currentProfile && (
          <BottomActions
            onPass={handlePass}
            onHeart={() => handleHeart()}
            onSuperHeart={handleSuperHeart}
            canSuperHeart={heartBalance >= 1}
          />
        )}

        {/* Bottom info bar */}
        <div style={{
          padding: "0 24px 20px",
          display: "flex", justifyContent: "center", gap: 24,
          borderTop: "1px solid #111",
          paddingTop: 12,
        }}>
          {[
            { label: "Feed", icon: "🔥" },
            { label: "Matches", icon: "💘" },
            { label: "Perfil", icon: "₿" },
            { label: "Gobernanza", icon: "🗳️" },
          ].map(item => (
            <button
              key={item.label}
              style={{
                display: "flex", flexDirection: "column", alignItems: "center", gap: 4,
                background: "none", border: "none", cursor: "pointer",
                fontFamily: "'Space Mono', monospace",
                fontSize: 9, color: "#555", letterSpacing: 0.5,
              }}
            >
              <span style={{ fontSize: 20 }}>{item.icon}</span>
              {item.label}
            </button>
          ))}
        </div>
      </div>
    </>
  );
}
